{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blog Index",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "date_created": {
        "type": "string",
        "format": "date-time"
      },
      "title": {
        "type": "string"
      },
      "url": {
        "type": "string",
        "format": "uri"
      }
    },
    "required": ["date_created", "title", "url"],
    "additionalProperties": false
  }
}